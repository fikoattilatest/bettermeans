<body>
  <script type="text/javascript">

    var _gaq = _gaq || [];
    _gaq.push(['_setAccount', 'UA-1630609-6']);
    _gaq.push(['_trackPageview']);

    (function() {
      var ga = document.createElement('script'); ga.type = 'text/javascript'; ga.async = true;
      ga.src = ('https:' == document.location.protocol ? 'https://ssl' : 'http://www') + '.google-analytics.com/ga.js';
      var s = document.getElementsByTagName('script')[0]; s.parentNode.insertBefore(ga, s);
    })();

  </script>

<%= yield %>

<%= render :partial => '/home/footer' %>

<script type="text/javascript">
            $(function() {
                $("#toTop").scrollToTop({speed:500,start:700});
            });

    $(document).ready(function() {
      $('.viewport').mouseenter(function(e) {
        $(this).children('a').children('img').animate({ height: '268', left: '-10', top: '-10', width: '480'}, 100);
        $(this).children('a').children('span').fadeIn(300);
      }).mouseleave(function(e) {
        $(this).children('a').children('img').animate({ height: '247', left: '0', top: '0', width: '460'}, 100);
        $(this).children('a').children('span').fadeOut(200);
      });

      /* Flash is dead: open the YouTube video in a modern iframe popup.
         The embed URL is derived from each link's href, supporting both the
         legacy youtube.com/v/ID form and the standard watch?v=ID form. */
      $(".videolink").click(function(e) {
        e.preventDefault();
        var href = this.href || '';
        var m = href.match(/(?:[?&]v=|\/v\/|\/embed\/|youtu\.be\/)([A-Za-z0-9_\-]+)/);
        var src = m ? ('https://www.youtube.com/embed/' + m[1] + '?autoplay=1&rel=0') : href;
        $.fancybox({
          'padding'       : 0,
          'width'         : 853,
          'height'        : 480,
          'type'          : 'iframe',
          'href'          : src,
          'titleShow'     : true,
          'title'         : this.title,
          'transitionIn'  : 'elastic',
          'transitionOut' : 'elastic'
        });
      });

      /* This is basic - uses default settings */
      $("a.fancy_image").fancybox({
        'transitionIn'  : 'elastic',
        'transitionOut'  : 'elastic'
      });

    });

        </script>
</body>
</html>
